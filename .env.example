# OOBE × Ace Data Cloud Bounty Agent Environment

# Ace Data Cloud Token (from https://platform.acedata.cloud)
ACE_DATA_CLOUD_TOKEN=your_ace_data_cloud_token_here

# Solana RPC Endpoint (Synapse RPC Gateway or standard)
SOLANA_RPC_URL=https://synapse.oobeprotocol.ai/free

# Private key of the agent wallet (absolute path, defaults to ~/.config/solana/id_agent.json)
AGENT_KEYPAIR_PATH=/home/kareltestspecial/.config/solana/id_agent.json
